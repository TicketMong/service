{
  "info": {
    "_postman_id": "b1efed55-9028-4497-a779-d01aaebc5e20",
    "name": "02 Reservation Create",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Prepare reservation inputs",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('concertId')) {",
              "  pm.environment.set('concertId', 'concert-e2e-reservation');",
              "}",
              "if (!pm.environment.get('showtimeId')) {",
              "  pm.environment.set('showtimeId', 'showtime-e2e-reservation');",
              "}",
              "if (!pm.environment.get('seatId')) {",
              "  pm.environment.set('seatId', 'seat-e2e-reservation-A-1');",
              "}",
              "pm.environment.set('reservationUserId', 'user-e2e-reservation');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('reservation inputs are prepared', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.environment.get('concertId')).to.be.a('string').that.is.not.empty;",
              "  pm.expect(pm.environment.get('showtimeId')).to.be.a('string').that.is.not.empty;",
              "  pm.expect(pm.environment.get('seatId')).to.be.a('string').that.is.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{reservationServiceUrl}}/health"
      }
    },
    {
      "name": "Start sales",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{reservationServiceUrl}}/admin/concerts/{{concertId}}/sales/start"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('sales are open', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.salesStatus).to.eql('open');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create reservation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-User-Id",
            "value": "{{reservationUserId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"concertId\":\"{{concertId}}\",\"showtimeId\":\"{{showtimeId}}\",\"performanceId\":\"{{showtimeId}}\",\"seatId\":\"{{seatId}}\"}"
        },
        "url": "{{reservationServiceUrl}}/reservations"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('reservation is created as pending hold', function () {",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.be.a('string');",
              "  pm.expect(body.userId).to.eql(pm.environment.get('reservationUserId'));",
              "  pm.expect(body.performanceId).to.eql(pm.environment.get('showtimeId'));",
              "  pm.expect(body.seatId).to.eql(pm.environment.get('seatId'));",
              "  pm.expect(body.status).to.eql('pending');",
              "  pm.expect(body.expiresAt).to.be.a('string');",
              "  pm.environment.set('reservationId', body.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List my reservations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-User-Id",
            "value": "{{reservationUserId}}"
          }
        ],
        "url": "{{reservationServiceUrl}}/reservations/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('my reservations include the created reservation', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items).to.be.an('array').that.is.not.empty;",
              "  const reservation = body.items.find((item) => item.id === pm.environment.get('reservationId'));",
              "  pm.expect(reservation).to.not.equal(undefined);",
              "  pm.expect(reservation.status).to.eql('pending');",
              "  pm.expect(reservation.seatId).to.eql(pm.environment.get('seatId'));",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
