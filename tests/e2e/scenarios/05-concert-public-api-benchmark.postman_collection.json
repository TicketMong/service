{
  "info": {
    "_postman_id": "9d037d83-24d9-46cf-9f67-0329a086ecb1",
    "name": "05 Concert Public API Benchmark",
    "description": "concert-service public booking API를 endpoint별로 독립 호출해 Newman duration을 분리 집계한다.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create benchmark venue",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Benchmark Hall {{$timestamp}}\",\"address\":\"Seoul\",\"totalSeats\":4}"
        },
        "url": "{{concertServiceUrl}}/provider/venues"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('benchmark venue is created', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.environment.set('benchmarkVenueId', pm.response.json().id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create benchmark concert",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Provider-Id",
            "value": "provider-benchmark"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\":\"Benchmark Live {{$timestamp}}\",\"description\":\"Public API benchmark dataset\",\"ageRating\":\"ALL\",\"runningMinutes\":120}"
        },
        "url": "{{concertServiceUrl}}/provider/concerts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('benchmark concert is created', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.environment.set('benchmarkConcertId', pm.response.json().id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create benchmark showtime",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const startsAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000);",
              "const endsAt = new Date(startsAt.getTime() + 2 * 60 * 60 * 1000);",
              "pm.environment.set('benchmarkStartsAt', startsAt.toISOString());",
              "pm.environment.set('benchmarkEndsAt', endsAt.toISOString());",
              "pm.environment.set('benchmarkYearMonth', startsAt.toISOString().slice(0, 7));",
              "pm.environment.set('benchmarkDate', startsAt.toISOString().slice(0, 10));",
              "pm.environment.set('benchmarkTargetSamples', '3');",
              "pm.environment.set('benchmarkStats', '{}');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('benchmark showtime is created', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.environment.set('benchmarkPerformanceId', pm.response.json().id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"venueId\":\"{{benchmarkVenueId}}\",\"startsAt\":\"{{benchmarkStartsAt}}\",\"endsAt\":\"{{benchmarkEndsAt}}\"}"
        },
        "url": "{{concertServiceUrl}}/provider/concerts/{{benchmarkConcertId}}/showtimes"
      }
    },
    {
      "name": "Upload benchmark seat map",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"sections\":[{\"name\":\"A\",\"rows\":[{\"name\":\"1\",\"seatNumbers\":[\"1\",\"2\",\"3\",\"4\"]}]}]}"
        },
        "url": "{{concertServiceUrl}}/provider/showtimes/{{benchmarkPerformanceId}}/seat-map"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('benchmark seat map is uploaded', function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Benchmark recommended concerts",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/recommended?sort=latest&limit=10"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('recommended response has card items only', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.items).to.be.an('array');",
              "  pm.expect(body.page.limit).to.eql(10);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Benchmark concert detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/{{benchmarkConcertId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('detail response excludes performances and seats', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('benchmarkConcertId'));",
              "  pm.expect(body.performances).to.equal(undefined);",
              "  pm.expect(body.seats).to.equal(undefined);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Benchmark concert calendar",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/{{benchmarkConcertId}}/calendar?yearMonth={{benchmarkYearMonth}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('calendar response has days with bookable only', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.days).to.be.an('array').that.is.not.empty;",
              "  const target = body.days.find((day) => day.date === pm.environment.get('benchmarkDate'));",
              "  pm.expect(target.bookable).to.eql(true);",
              "  pm.expect(target.performanceCount).to.equal(undefined);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Benchmark date performances",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/{{benchmarkConcertId}}/dates/{{benchmarkDate}}/performances"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('date performances response has selected date only', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.date).to.eql(pm.environment.get('benchmarkDate'));",
              "  pm.expect(body.performances).to.be.an('array').with.lengthOf(1);",
              "  pm.expect(body.performances[0].performanceId).to.eql(pm.environment.get('benchmarkPerformanceId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Benchmark performance seat map",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/performances/{{benchmarkPerformanceId}}/seat-map"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('seat map response has sections and seats', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.performanceId).to.eql(pm.environment.get('benchmarkPerformanceId'));",
              "  pm.expect(body.sections).to.be.an('array').with.lengthOf(1);",
              "  pm.expect(body.seats).to.be.an('array').with.lengthOf(4);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Benchmark summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('benchmark summary is complete', function () {",
              "  pm.response.to.have.status(200);",
              "  const stats = JSON.parse(pm.environment.get('benchmarkStats') || '{}');",
              "  ['recommended', 'detail', 'calendar', 'datePerformances', 'seatMap'].forEach(function (name) {",
              "    pm.expect(stats[name], name).to.not.equal(undefined);",
              "    pm.expect(stats[name].count, name + ' count').to.eql(Number(pm.environment.get('benchmarkTargetSamples')));",
              "  });",
              "  console.log('concert public api benchmark stats: ' + JSON.stringify(stats));",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const benchmarks = {",
          "  'Benchmark recommended concerts': { name: 'recommended', status: 200 },",
          "  'Benchmark concert detail': { name: 'detail', status: 200 },",
          "  'Benchmark concert calendar': { name: 'calendar', status: 200 },",
          "  'Benchmark date performances': { name: 'datePerformances', status: 200 },",
          "  'Benchmark performance seat map': { name: 'seatMap', status: 200 }",
          "};",
          "const benchmark = benchmarks[pm.info.requestName];",
          "if (benchmark) {",
          "  pm.test(benchmark.name + ' status ' + benchmark.status, function () {",
          "    pm.response.to.have.status(benchmark.status);",
          "  });",
          "  const target = Number(pm.environment.get('benchmarkTargetSamples') || '3');",
          "  const stats = JSON.parse(pm.environment.get('benchmarkStats') || '{}');",
          "  const current = stats[benchmark.name] || { endpoint: pm.request.url.toString(), status: benchmark.status, count: 0, durations: [] };",
          "  current.count += 1;",
          "  current.durations.push(pm.response.responseTime);",
          "  current.minMs = Math.min.apply(null, current.durations);",
          "  current.maxMs = Math.max.apply(null, current.durations);",
          "  current.avgMs = Math.round((current.durations.reduce(function (sum, value) { return sum + value; }, 0) / current.durations.length) * 100) / 100;",
          "  stats[benchmark.name] = current;",
          "  pm.environment.set('benchmarkStats', JSON.stringify(stats));",
          "  if (current.count < target) {",
          "    pm.execution.setNextRequest(pm.info.requestName);",
          "  }",
          "}"
        ]
      }
    }
  ]
}
