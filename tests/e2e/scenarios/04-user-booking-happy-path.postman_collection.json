    {
      "name": "티켓 발행 polling",
      "description": "payment-approved 이벤트가 Kafka를 거쳐 ticket-service에서 티켓을 만들 때까지 짧게 polling한다.",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-User-Id",
            "value": "{{e2eUserId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{e2eUserRole}}"
          }
        ],
        "url": "{{ticketServiceUrl}}/tickets/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const maxAttempts = 20;",
              "const attempt = Number(pm.environment.get('ticketPollAttempt') || '0') + 1;",
              "pm.response.to.have.status(200);",
              "const body = pm.response.json();",
              "const tickets = Array.isArray(body) ? body : body.items;",
              "pm.expect(tickets).to.be.an('array');",
              "const ticket = tickets.find((item) => item.reservationId === pm.environment.get('reservationId'));",
              "",
              "if (!ticket && attempt < maxAttempts) {",
              "  pm.environment.set('ticketPollAttempt', String(attempt));",
              "  pm.execution.setNextRequest(pm.info.requestName);",
              "  pm.test('티켓 발행을 기다리는 중', function () {",
              "    pm.expect(attempt, 'poll attempt').to.be.below(maxAttempts);",
              "  });",
              "} else if (!ticket) {",
              "  pm.environment.unset('ticketPollAttempt');",
              "  pm.test('payment-approved 이벤트 이후 티켓이 제한 시간 안에 생성된다', function () {",
              "    throw new Error(`reservationId=${pm.environment.get('reservationId')} 티켓을 ${maxAttempts}회 polling 동안 찾지 못했습니다.`);",
              "  });",
              "} else {",
              "  pm.environment.unset('ticketPollAttempt');",
              "  pm.test('결제 승인 이벤트로 티켓이 생성된다', function () {",
              "    pm.expect(ticket.reservationId).to.eql(pm.environment.get('reservationId'));",
              "    pm.expect(ticket.userId).to.eql(pm.environment.get('e2eUserId'));",
              "    pm.expect(ticket.concertId).to.eql(pm.environment.get('concertId'));",
              "    pm.expect(ticket.seatId).to.eql(pm.environment.get('seatId'));",
              "    pm.expect(ticket.status).to.eql('ISSUED');",
              "    pm.expect(ticket.qrUrl === null || typeof ticket.qrUrl === 'string', 'qrUrl은 문자열 또는 null').to.eql(true);",
              "    pm.expect(ticket.pdfUrl === null || typeof ticket.pdfUrl === 'string', 'pdfUrl은 문자열 또는 null').to.eql(true);",
              "    pm.environment.set('ticketId', String(ticket.id));",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "예약 생성 알림 polling",
