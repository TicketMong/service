      "description": "사용자가 실제 조회해 예약할 수 있는 좌석 2개를 생성한다.",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"sections\":[{\"name\":\"A\",\"rows\":[{\"name\":\"1\",\"seatNumbers\":[\"1\",\"2\"]}]}]}"
        },
        "url": "{{concertServiceUrl}}/provider/showtimes/{{showtimeId}}/seat-map"
      },
      "event": [
        {
