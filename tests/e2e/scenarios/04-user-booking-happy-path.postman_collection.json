              "  pm.environment.unset('reservationNotificationPollAttempt');",
              "  pm.test('reservation-created 알림이 제한 시간 안에 저장된다', function () {",
              "    throw new Error(`reservation-created 알림을 ${maxAttempts}회 polling 동안 찾지 못했습니다. reservationId=${pm.environment.get('reservationId')}`);",
              "  });",
