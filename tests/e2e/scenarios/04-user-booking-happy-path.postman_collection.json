      ]
    },
    {
      "name": "추천 공연 조회",
      "description": "사용자가 홈에서 최신 추천 공연을 보고 방금 준비한 공연을 선택할 수 있는지 확인한다.",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/recommended?sort=latest&limit=10"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('추천 공연 목록에 생성한 공연이 포함된다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items).to.be.an('array').that.is.not.empty;",
              "  pm.expect(body.page.limit).to.eql(10);",
              "  const concert = body.items.find((item) => (item.concertId || item.id) === pm.environment.get('concertId'));",
              "  pm.expect(concert, '생성한 concertId').to.not.equal(undefined);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "공연 상세 조회",
      "description": "추천 공연에서 선택한 공연의 상세 화면에 진입한다.",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/{{concertId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('공연 상세를 조회할 수 있다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.concertId || body.id).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.performances).to.equal(undefined);",
              "  pm.expect(body.seats).to.equal(undefined);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "공연 달력 조회",
      "description": "공연 상세에서 예매 가능한 날짜를 달력으로 확인한다.",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/{{concertId}}/calendar?yearMonth={{concertYearMonth}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('달력에서 생성한 회차 날짜가 예매 가능하다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.yearMonth).to.eql(pm.environment.get('concertYearMonth'));",
              "  pm.expect(body.days).to.be.an('array').that.is.not.empty;",
              "  const targetDay = body.days.find((day) => day.date === pm.environment.get('concertDate'));",
              "  pm.expect(targetDay, '생성한 concertDate').to.not.equal(undefined);",
              "  pm.expect(targetDay.bookable).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "날짜별 회차 조회",
      "description": "사용자가 달력에서 선택한 날짜의 회차를 확인하고 예매할 performanceId를 저장한다.",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/concerts/{{concertId}}/dates/{{concertDate}}/performances"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('날짜별 회차 목록에 생성한 회차가 포함된다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.date).to.eql(pm.environment.get('concertDate'));",
              "  pm.expect(body.performances).to.be.an('array').that.is.not.empty;",
              "  const performance = body.performances.find((item) => (item.performanceId || item.id) === pm.environment.get('showtimeId'));",
              "  pm.expect(performance, '생성한 showtimeId').to.not.equal(undefined);",
              "  pm.expect(performance.saleStatus).to.eql('ON_SALE');",
              "  const performanceId = performance.performanceId || performance.id;",
              "  pm.environment.set('performanceId', performanceId);",
              "  pm.environment.set('showtimeId', performanceId);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "좌석도 조회",
      "description": "선택한 회차의 좌석도에서 사용자가 선택할 수 있는 좌석을 고른다. 예약 후 concert-service 좌석 상태 동기화는 검증하지 않는다.",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{concertServiceUrl}}/performances/{{performanceId}}/seat-map"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('좌석도에서 예약할 수 있는 좌석을 선택한다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.performanceId || body.id).to.eql(pm.environment.get('performanceId'));",
              "  pm.expect(body.sections).to.be.an('array').that.is.not.empty;",
              "  pm.expect(body.seats).to.be.an('array').with.lengthOf(2);",
              "  const targetSeat = body.seats.find((item) => (item.sectionId || item.section) === 'A' && item.row === '1' && item.number === '1');",
              "  pm.expect(targetSeat, 'A-1 좌석').to.not.equal(undefined);",
              "  pm.expect(String(targetSeat.status).toUpperCase()).to.eql('AVAILABLE');",
              "  pm.environment.set('seatId', targetSeat.seatId || targetSeat.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "판매 시작",
      "description": "reservation-service 기준 판매 상태를 열어 예약 생성을 허용한다.",
      "request": {
        "method": "POST",
        "header": [],
        "url": "{{reservationServiceUrl}}/admin/concerts/{{concertId}}/sales/start"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('예약 서비스에서 판매가 열린다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.salesStatus).to.eql('open');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "예약 생성",
      "description": "로그인 사용자 sub를 X-User-Id 문자열로 전달해 실제 사용자 조회 절차에서 선택한 concertId/performanceId/seatId로 예약한다.",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-User-Id",
            "value": "{{e2eUserId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"concertId\":\"{{concertId}}\",\"showtimeId\":\"{{performanceId}}\",\"performanceId\":\"{{performanceId}}\",\"seatId\":\"{{seatId}}\"}"
        },
        "url": "{{reservationServiceUrl}}/reservations"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('로그인 사용자 기준 예약이 생성된다', function () {",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.be.a('string').that.is.not.empty;",
              "  pm.expect(body.userId).to.eql(pm.environment.get('e2eUserId'));",
              "  pm.expect(body.performanceId).to.eql(pm.environment.get('performanceId'));",
              "  pm.expect(body.seatId).to.eql(pm.environment.get('seatId'));",
              "  pm.expect(body.status).to.eql('pending');",
              "  pm.environment.set('reservationId', body.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "내 예약 목록 조회",
      "description": "생성한 예약이 같은 사용자 컨텍스트의 예약 목록에 노출되는지 확인한다.",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-User-Id",
            "value": "{{e2eUserId}}"
          }
        ],
        "url": "{{reservationServiceUrl}}/reservations/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('내 예약 목록에 생성한 예약이 포함된다', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items).to.be.an('array').that.is.not.empty;",
              "  const reservation = body.items.find((item) => item.id === pm.environment.get('reservationId'));",
              "  pm.expect(reservation, '생성한 reservationId').to.not.equal(undefined);",
