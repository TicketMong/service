    {
      "name": "회차 생성",
      "description": "공연에 연결된 실제 예매 회차를 생성하고 public calendar/date 조회에 쓸 날짜 변수를 저장한다.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// 항상 미래 회차를 만들기 위해 현재 시각 기준 7일 뒤를 사용한다.",
              "const startsAt = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000);",
              "const startsAtIso = startsAt.toISOString();",
              "pm.environment.set('concertStartsAt', startsAtIso);",
              "pm.environment.set('concertYearMonth', startsAtIso.slice(0, 7));",
              "pm.environment.set('concertDate', startsAtIso.slice(0, 10));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('회차가 생성된다', function () {",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.be.a('string').that.is.not.empty;",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.venueId).to.eql(pm.environment.get('venueId'));",
              "  pm.environment.set('showtimeId', body.id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"venueId\":\"{{venueId}}\",\"startsAt\":\"{{concertStartsAt}}\"}"
        },
        "url": "{{concertServiceUrl}}/provider/concerts/{{concertId}}/showtimes"
      }
    },
    {
