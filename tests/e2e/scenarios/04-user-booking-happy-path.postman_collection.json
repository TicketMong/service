              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "mock 결제 승인",
      "description": "payment-service에 gateway header를 전달하고 mock approve 결제를 생성한다. 이 결제가 payment-approved 이벤트를 만들어 ticket/notification 흐름의 출발점이 된다.",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-User-Id",
            "value": "{{e2eUserId}}"
          },
          {
            "key": "X-User-Role",
            "value": "{{e2eUserRole}}"
          },
          {
            "key": "X-User-Email",
            "value": "{{e2eUserEmail}}"
          },
          {
            "key": "X-Token-Id",
            "value": "{{e2eTokenId}}"
          },
          {
            "key": "Idempotency-Key",
            "value": "e2e-booking-{{reservationId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"reservationId\":\"{{reservationId}}\",\"concertId\":\"{{concertId}}\",\"seatId\":\"{{seatId}}\",\"amount\":50000,\"method\":\"mock\",\"simulation\":\"approve\"}"
        },
        "url": "{{paymentServiceUrl}}/payments"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('mock approve 결제가 승인된다', function () {",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.be.a('string').that.is.not.empty;",
              "  pm.expect(body.reservationId).to.eql(pm.environment.get('reservationId'));",
              "  pm.expect(body.concertId).to.eql(pm.environment.get('concertId'));",
              "  pm.expect(body.status).to.eql('approved');",
              "  pm.expect(body.approvedAt).to.be.a('string').that.is.not.empty;",
              "  pm.environment.set('paymentId', body.id);",
              "});"
